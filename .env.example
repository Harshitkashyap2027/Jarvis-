# ============================================================
# Project A.E.T.H.E.R. Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ============================================================

# --- Server Configuration ---
PORT=3000
HOST=127.0.0.1

# --- AI / LLM Provider ---
# Choose one: "openai" | "gemini" | "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Google Gemini (alternative)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Feature Flags ---
# Enable hardware macro control via robotjs (requires native build tools)
ENABLE_MACRO_CONTROL=false

# Default project workspace directory (used by dev orchestrator)
WORKSPACE_DIR=/home/user/projects

# Downloads directory for auto-organizer
DOWNLOADS_DIR=/home/user/Downloads
